# Endereço do Ollama rodando localmente
OLLAMA_HOST=http://localhost:11434

# Modelo a ser usado (baixe antes com: ollama pull <modelo>)
# Sugestões: llama3.2, codellama, deepseek-coder-v2, qwen2.5-coder
OLLAMA_MODEL=llama3.2

# Origens permitidas para CORS (separadas por vírgula).
# Inclua a URL do frontend em produção (ex: https://seu-usuario.github.io)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
